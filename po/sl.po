#: desktop-portal/background.c:919
#, c-format
msgid "Allow %s to Run in the Background?"
msgstr "Dovolite, da %s deluje v ozadju?"

#: desktop-portal/background.c:923
#, c-format
msgid "%s wants to be started automatically and run in the background"
msgstr "%s zahteve samodejni zagon in izvajanje v ozadju."

#: desktop-portal/background.c:925
#, c-format
msgid "%s wants to run in the background"
msgstr "%s zahteve izvajanje v ozadju."

#: desktop-portal/background.c:926
msgid ""
"The ‘run in background’ permission can be changed at any time from the app "
"settings"
msgstr ""
"Dovoljenje »zaženi v ozadju« lahko kadar koli spremenite v nastavitvah "
"programa."

#: desktop-portal/background.c:930
msgid "Don't allow"
msgstr "Ne dovoli"

#: desktop-portal/background.c:931 desktop-portal/screenshot.c:261
#: desktop-portal/wallpaper.c:174
msgid "Allow"
msgstr "Dovoli"

#: desktop-portal/camera.c:90
#, c-format
msgid "Allow %s to Use the Camera?"
msgstr "Dovolite %s uporabo kamere?"

#: desktop-portal/camera.c:91
#, c-format
msgid "%s wants to access the camera"
msgstr "%s želi dostopati do kamere."

#: desktop-portal/camera.c:95
msgid "Allow Apps to Use the Camera?"
msgstr "Ali programom dovolite uporabo kamere?"

#: desktop-portal/camera.c:96
msgid "An app wants to access the camera"
msgstr "Program želi dostopati do kamere."

#: desktop-portal/camera.c:99 desktop-portal/screenshot.c:313
#: desktop-portal/wallpaper.c:190
msgid "This permission can be changed at any time from the privacy settings"
msgstr "To dovoljenje lahko kadar koli spremenite v nastavitvah zasebnosti."

#: desktop-portal/dynamic-launcher.c:109
#, c-format
msgid "Desktop file id missing .desktop suffix: %s"
msgstr "ID-ju namizne datoteke manjka pripona .desktop: %s"

#: desktop-portal/dynamic-launcher.c:120
#, c-format
msgid "Desktop file id is not valid"
msgstr "ID namizne datoteke ni veljaven"

#: desktop-portal/dynamic-launcher.c:298
#, c-format
msgid "Desktop entry given to Install() not a valid key file"
msgstr ""
"Vnos na namizju, podan funkciji Install(), ni veljavna datoteka s ključem"

#: desktop-portal/dynamic-launcher.c:311
#, c-format
msgid "Desktop entry given to Install() must have exactly one group"
msgstr ""
"Vnos na namizju, podan funkciji Install(), mora imeti natanko eno skupino"

#: desktop-portal/dynamic-launcher.c:350
#, c-format
msgid "Token given is invalid: %s"
msgstr "Podani žeton je neveljaven: %s"

#: desktop-portal/dynamic-launcher.c:393
#, c-format
msgid "Desktop entry given to Install() not valid"
msgstr "Vnos na namizju, podan funkciji Install(), ni veljaven"

#: desktop-portal/dynamic-launcher.c:402 desktop-portal/dynamic-launcher.c:878
#: desktop-portal/dynamic-launcher.c:927
#, c-format
msgid "Desktop file exceeds max size (%d): %s"
msgstr "Namizna datoteka presega največjo velikost (%d): %s"

#: desktop-portal/dynamic-launcher.c:600
#, c-format
msgid "Given URI is invalid: %s"
msgstr "Navedeni URI je neveljaven: %s"

#: desktop-portal/dynamic-launcher.c:622
#, c-format
msgid "Invalid launcher type: %x"
msgstr "Neveljavna vrsta zaganjalnika: %x"

#: desktop-portal/dynamic-launcher.c:629
#, c-format
msgid "Unsupported launcher type: %x"
msgstr "Nepodprta vrsta zaganjalnika: %x"

#: desktop-portal/dynamic-launcher.c:695 desktop-portal/dynamic-launcher.c:770
msgid "Dynamic launcher icon failed validation"
msgstr "Preverjanje veljavnosti ikone dinamičnega zaganjalnika ni uspelo"

#: desktop-portal/dynamic-launcher.c:788
#, c-format
msgid "RequestInstallToken() not allowed for app id %s"
msgstr "RequestInstallToken() ni dovoljeno za ID programa %s"

#: desktop-portal/dynamic-launcher.c:967
#, c-format
msgid "Desktop file '%s' icon at unrecognized path"
msgstr "Ikona namizne datoteke »%s« je na neprepoznani poti"

#: desktop-portal/dynamic-launcher.c:990
#, c-format
msgid "Desktop file '%s' icon failed to serialize"
msgstr "Ikone namizne datoteke »%s« ni bilo mogoče serializirati"

#: desktop-portal/dynamic-launcher.c:1029
#, c-format
msgid "No dynamic launcher exists with id '%s'"
msgstr "Noben dinamični zaganjalnik ne obstaja z ID-jem »%s«"

#: desktop-portal/dynamic-launcher.c:1048
#, c-format
msgid "Failed to create GDesktopAppInfo for launcher with id '%s'"
msgstr "Za zaganjalnik z ID-jem »%s« ni uspelo ustvariti GDesktopAppInfo"

#: desktop-portal/location.c:537
msgid "Deny Access"
msgstr "Zavrni dostop"

#: desktop-portal/location.c:539
msgid "Grant Access"
msgstr "Dovoli dostop"

#: desktop-portal/location.c:545
#, c-format
msgid "Allow %s to Access Your Location?"
msgstr "Ali dovolite %s dostop do svoje lokacije?"

#: desktop-portal/location.c:555
#, c-format
msgid "%s wants to use your location"
msgstr "%s želi uporabiti vašo lokacijo."

#: desktop-portal/location.c:561
msgid "Allow Apps to Access Your Location?"
msgstr "Dovolite programom dostop do vaše lokacije?"

#: desktop-portal/location.c:562
msgid "An app wants to use your location"
msgstr "Program želi uporabiti vašo lokacijo."

#: desktop-portal/location.c:565
msgid "Location access can be changed at any time from the privacy settings"
msgstr ""
"Dostop do trenutne lokacije je mogoče spremeniti kadarkoli med nastavitvami "
"zasebnosti."

#: desktop-portal/screenshot.c:259 desktop-portal/wallpaper.c:172
msgid "Deny"
msgstr "Zavrni"

#: desktop-portal/screenshot.c:285
#, c-format
msgid "Allow %s to Take Screenshots?"
msgstr "Dovolite %s snemanja posnetkov zaslona?"

#: desktop-portal/screenshot.c:286
#, c-format
msgid "%s wants to take screenshots at any time"
msgstr "%s želi imeti pravice, da kadar koli zajame posnetke zaslona."

#: desktop-portal/screenshot.c:290
#, c-format
msgid "Allow %s to Take a Screenshot?"
msgstr "Dovolite %s narediti posnetek zaslona?"

#: desktop-portal/screenshot.c:291
#, c-format
msgid "%s wants to take a screenshot"
msgstr "%s želi narediti posnetek zaslona."

#. Note: this will set the screenshot permission for all unsandboxed
#. * apps for which an app ID can't be determined.
#.
#: desktop-portal/screenshot.c:302
msgid "Allow Apps to Take Screenshots?"
msgstr "Dovolite programom snemanje posnetkov zaslona?"

#: desktop-portal/screenshot.c:303
msgid "An app wants to take screenshots at any time"
msgstr "Program želi kadar koli narediti posnetke zaslona."

#: desktop-portal/screenshot.c:307
msgid "Allow to Take a Screenshot?"
msgstr "Dovolite snemanje posnetkov zaslona?"

#: desktop-portal/screenshot.c:308
msgid "An app wants to take a screenshot"
msgstr "Program želi narediti posnetek zaslona."

#: desktop-portal/settings.c:178 desktop-portal/settings.c:217
msgid "Requested setting not found"
msgstr "Zahtevane nastavitve ni bilo mogoče najti"

#: desktop-portal/usb.c:1314
msgid "Device not available"
msgstr "Naprava ni na voljo"

#: desktop-portal/usb.c:1328
msgid "Not allowed"
msgstr "Ni dovoljeno"

#: desktop-portal/wallpaper.c:180
#, c-format
msgid "Allow %s to Set Backgrounds?"
msgstr "Dovolite %s nastavitev ozadij?"

#: desktop-portal/wallpaper.c:181
#, c-format
msgid "%s wants to change the background image"
msgstr "%s zahteva spremembo slike ozadja."

#: desktop-portal/wallpaper.c:186
msgid "Allow Apps to Set Backgrounds?"
msgstr "Dovolite programom nastavljati ozadja?"

#: desktop-portal/wallpaper.c:187
msgid "An app wants to change the background image"
msgstr "Program zahteva spremembo slike ozadja."
